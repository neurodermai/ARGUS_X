# ═══════════════════════════════════════════════════════════════════════════════
# ARGUS-X — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env in the same directory:
#   cp .env.example .env
#
# A root-level copy also exists at the repo root for reference.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Supabase (required for DB — runs in memory-only mode without these) ──────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# SECURITY: The service key bypasses Row Level Security (RLS).
# It must ONLY be used in the backend. NEVER expose it to frontend or logs.
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Anon key respects RLS — used by the backend for all read operations.
# REQUIRED for production: ensures reads cannot bypass Row Level Security.
# In dev/demo mode, reads fall back to service key with a warning if unset.
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ── Environment Mode ─────────────────────────────────────────────────────────
# Set to "production" in deployed environments.
# SECURITY: When ENV=production and API_KEY is empty, the server will
# refuse to start (fail-fast). In all other modes it logs a warning only.
ENV=development

# ── API Authentication (optional in dev — REQUIRED in production) ────────────
# When set, all /api/v1 endpoints require X-API-Key header.
# When empty, auth is DISABLED (local dev / demo mode).
# CRITICAL: Production MUST have this set — server will crash without it.
API_KEY=

# When set, /api/v1/redteam requires X-RedTeam-Token header.
# Adds extra protection on the compute-heavy red team endpoint.
REDTEAM_TOKEN=

# ── LLM (optional — runs in realistic mock mode if both empty) ───────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-3-5-haiku-20241022

# ── HuggingFace ML Model (optional — runs rule-only mode without) ────────────
# Base model: protectai/deberta-v3-base-prompt-injection-v2
# Export to ONNX first: python scripts/export_onnx.py
# If using a custom HF repo with pre-exported ONNX, set HF_MODEL_REPO below.
HF_MODEL_REPO=
HF_TOKEN=
MODEL_DIR=./models

# ── Redis Session Store (optional — uses in-memory fallback without) ─────────
REDIS_URL=

# ── CORS (optional — defaults to localhost:3000,5173,8000) ───────────────────
CORS_ORIGINS=

# ── Server (Railway sets PORT automatically) ─────────────────────────────────
PORT=8000

# ── Monitoring (optional) ────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
