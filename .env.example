# ═══════════════════════════════════════════════════════════════════════
# ARGUS-X Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════

# ── LLM (optional — mock mode if both empty) ──────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-3-haiku-20240307

# ── Supabase (required for production) ────────────────────────────────
SUPABASE_URL=https://dzanurqcmjxhkvuqrasz.supabase.co
SUPABASE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── HuggingFace (ML model hosting) ───────────────────────────────────
HF_MODEL_REPO=NeuroDermAI/argus-x-classifier
HF_TOKEN=

# ── Model Config ─────────────────────────────────────────────────────
MODEL_DIR=./models

# ── Monitoring (optional) ────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
