{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "cd argus/frontend && npm ci && npm run build",
  "outputDirectory": "argus/frontend/dist",
  "installCommand": "cd argus/frontend && npm ci",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "${VITE_API_URL}/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "${VITE_WS_URL}/ws/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
